<%- include('../partials/_navbar.ejs', { title: 'New Application' }) %>
<body>
    <form action="/users/<%= user._id %>/applications/" method="POST">
        <div>
            <label for="company">Company:</label>
        <input type="text" name="company" id="company" placeholder="IBM" required />
    </div>
        <div>
            <label for="title">Title:</label>
            <input type="text" name="title" id="title" placeholder="Custodial Engineer" required />
        </div>
        <div>
            <label for="notes">Notes:</label>
            <textarea type="text" name="notes" id="notes" placeholder="Isn't that a janitor?"></textarea>
        </div>
       <div>
            <label for="postingLink">Posting Link:</label>
            <input type="text" name="postingLink" id="postingLink" placeholder="ibm.com/app/12345" />
       </div>
        <div>
            <label for="status">Status:</label>
            <select name="status" id="status">
                <% ['interested', 'applied' , 'interviewing' , 'rejected' , 'accepted' ].forEach(status=> { %>
                    <option value="<%= status %>">
                        <%= status.charAt(0).toUpperCase() + status.split('').slice(1).join('') %>
                    </option>
                    <% }) %>
            </select>
        </div>
        <div>
            <button type="submit">Submit</button>
        </div>
    </form>
</body>
</html>